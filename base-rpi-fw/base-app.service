[Unit]
Description=Garden E-Cutters Base App
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/Garden-E-Cutters/base-rpi-fw
ExecStart=/home/pi/Garden-E-Cutters/base-rpi-fw/start_app.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target